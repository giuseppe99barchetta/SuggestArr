{
  "customSyntax": "postcss-html",
  "rules": {
    "declaration-property-value-disallowed-list": [
      {
      "/^(color|background|background-color|border-color|outline-color|text-decoration-color|fill|stroke)$/": "/#[0-9a-fA-F]{3,8}\\b|\\brgba?\\(|\\bhsla?\\(/i",
      "/^(margin(|-(top|right|bottom|left))|padding(|-(top|right|bottom|left))|gap|row-gap|column-gap)$/": "/(^|\\s)\\d(\\.\\d+)?(px|rem|em)\\b/i",
      "/^border-radius$|^border-(top-left|top-right|bottom-left|bottom-right)-radius$/": "/(^|\\s)\\d(\\.\\d+)?(px|rem|em|%)\\b/i",
      "/^font-size$/": "/(^|\\s)\\d(\\.\\d+)?(px|rem|em)\\b/i"
      },
      {
        "severity": "warning"
      }
    ]
  }
}
